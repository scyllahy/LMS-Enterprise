const SystemMonitorService=Object.freeze({healthCheck(c){const s=Date.now(),checks=[];[['DATABASE',()=>DB.ss().getName()],['DRIVE',()=>StorageService.root().getName()],['MAIL',()=>MailApp.getRemainingDailyQuota()]].forEach(x=>{try{checks.push({name:x[0],status:'HEALTHY',value:x[1]()})}catch(e){checks.push({name:x[0],status:'CRITICAL',message:e.message})}});const status=checks.some(x=>x.status==='CRITICAL')?'CRITICAL':'HEALTHY';return HealthRepository.insert({overallStatus:status,checksJson:checks,checkedAt:Utils.now(),durationMs:Date.now()-s},{actorId:c.userId})}});
