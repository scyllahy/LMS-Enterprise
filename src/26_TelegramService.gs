const TelegramService=Object.freeze({sendNotification(n,d){return this.sendMessage(d.destination,'<b>'+Utils.escape(n.title)+'</b>\n\n'+Utils.escape(n.message))},sendMessage(id,text){const t=Props.required('TELEGRAM_BOT_TOKEN'),r=UrlFetchApp.fetch('https://api.telegram.org/bot'+t+'/sendMessage',{method:'post',contentType:'application/json',payload:JSON.stringify({chat_id:String(id),text,parse_mode:'HTML'}),muteHttpExceptions:true}),d=Utils.parse(r.getContentText(),{});if(!d.ok)throw new AppError('TELEGRAM_API_ERROR',d.description||'Telegram error');return{success:true,messageId:d.result.message_id}},adminAlert(title,msg){return Props.get('TELEGRAM_ADMIN_CHAT_IDS','').split(',').filter(Boolean).map(id=>this.sendMessage(id,'🚨 <b>'+Utils.escape(title)+'</b>\n'+Utils.escape(msg)))}});
