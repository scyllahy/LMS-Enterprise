const ReportService=Object.freeze({dashboard(){return{users:UserRepository.count({status:APP_STATUSES.ACTIVE}),students:StudentRepository.count({status:APP_STATUSES.ACTIVE}),teachers:TeacherRepository.count({status:APP_STATUSES.ACTIVE}),quizzes:QuizRepository.count({status:APP_STATUSES.ACTIVE}),activeAttempts:AttemptRepository.count({examStatus:EXAM_STATUSES.IN_PROGRESS})}},quiz(c,id){PermissionService.requireAny(c,['report.read','system.manage']);const a=ScoreRepository.findMany({quizId:id}),v=a.map(x=>Utils.num(x.percentage));return{total:a.length,average:v.length?v.reduce((x,y)=>x+y,0)/v.length:0,passed:a.filter(x=>Utils.bool(x.passed)).length}}});
