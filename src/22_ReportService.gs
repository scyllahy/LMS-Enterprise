const ReportService=Object.freeze({dashboard(year){const wanted=normalizeAcademicYear_(year),classes=ClassRepository.all().filter(x=>wanted==='ALL'||academicYearOf_(x)===wanted),classIds=classes.map(x=>x.classId),quizzes=QuizRepository.findMany({status:APP_STATUSES.ACTIVE}).filter(x=>wanted==='ALL'||academicYearOf_(x)===wanted),quizIds=quizzes.map(x=>x.quizId);return{users:UserRepository.count({status:APP_STATUSES.ACTIVE}),students:StudentRepository.findMany({status:APP_STATUSES.ACTIVE}).filter(x=>classIds.includes(x.classId)).length,teachers:TeacherRepository.count({status:APP_STATUSES.ACTIVE}),quizzes:quizzes.length,activeAttempts:AttemptRepository.findMany({examStatus:EXAM_STATUSES.IN_PROGRESS}).filter(x=>quizIds.includes(x.quizId)).length}},quiz(c,id){PermissionService.requireAny(c,['report.read','system.manage']);const a=ScoreRepository.findMany({quizId:id}),v=a.map(x=>Utils.num(x.percentage));return{total:a.length,average:v.length?v.reduce((x,y)=>x+y,0)/v.length:0,passed:a.filter(x=>Utils.bool(x.passed)).length}}});
