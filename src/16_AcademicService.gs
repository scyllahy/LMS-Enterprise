const AcademicService=Object.freeze({createClass(c,p){PermissionService.requireAny(c,['class.create','system.manage']);return ClassRepository.insert(p,{actorId:c.userId})},createSubject(c,p){PermissionService.requireAny(c,['subject.create','system.manage']);return SubjectRepository.insert(p,{actorId:c.userId})},createStudent(c,p){PermissionService.requireAny(c,['student.create','system.manage']);return StudentRepository.insert(p,{actorId:c.userId})},createTeacher(c,p){PermissionService.requireAny(c,['teacher.create','system.manage']);return TeacherRepository.insert(p,{actorId:c.userId})}});
