const DB=Object.freeze({ss(){let id=Props.get('LMS_SPREADSHEET_ID');if(!id){const s=SpreadsheetApp.create(APP_CONFIG.app.name+' Database');id=s.getId();Props.set('LMS_SPREADSHEET_ID',id);return s}return SpreadsheetApp.openById(id)},sheet(name,headers){const ss=this.ss();let sh=ss.getSheetByName(name);if(!sh)sh=ss.insertSheet(name);if(headers&&headers.length&&sh.getLastRow()===0)sh.getRange(1,1,1,headers.length).setValues([headers]);return sh}});
