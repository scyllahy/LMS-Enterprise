const UserService=Object.freeze({create(c,p){PermissionService.requireAny(c,['user.create','system.manage']);p=requireObject_(p);const u=requireNonBlank_(p.username,'username').toLowerCase();if(UserRepository.findOne({username:u}))throw AppError.conflict('ชื่อผู้ใช้นี้มีอยู่แล้ว');const h=Security.hash(requireNonBlank_(p.password,'password'));return cleanUser_(UserRepository.insert({username:u,email:Utils.email(p.email),displayName:Utils.text(p.displayName),passwordHash:h.hash,salt:h.salt,role:p.role||APP_ROLES.STUDENT,permissionsJson:Utils.arr(p.permissions),mustChangePassword:Utils.bool(p.mustChangePassword,true),lastLoginAt:'',metadataJson:p.metadataJson||{}},{actorId:c.userId}))},list(c){PermissionService.requireAny(c,['user.read','system.manage']);return UserRepository.findMany({status:APP_STATUSES.ACTIVE}).map(cleanUser_)},get(c,id){const u=UserRepository.findById(id);if(!u)throw AppError.notFound('ไม่พบผู้ใช้');return cleanUser_(u)}});function cleanUser_(u){const x=Object.assign({},u);delete x.passwordHash;delete x.salt;return x}
