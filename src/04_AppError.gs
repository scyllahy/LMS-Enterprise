class AppError extends Error{constructor(code,message,details){super(message);this.code=code||'INTERNAL_ERROR';this.details=details||null}static validation(m,d){return new AppError('VALIDATION_ERROR',m,d)}static notFound(m){return new AppError('NOT_FOUND',m)}static permission(m){return new AppError('PERMISSION_DENIED',m||'ไม่มีสิทธิ์')}static conflict(m){return new AppError('CONFLICT',m)}static configuration(m){return new AppError('CONFIGURATION_ERROR',m)}static internal(e){return e instanceof AppError?e:new AppError('INTERNAL_ERROR',e&&e.message?e.message:String(e))}}
