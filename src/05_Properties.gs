const Props=Object.freeze({get:(k,d='')=>PropertiesService.getScriptProperties().getProperty(k)??d,set:(k,v)=>PropertiesService.getScriptProperties().setProperty(k,String(v)),required(k){const v=this.get(k);if(!v)throw AppError.configuration('ไม่พบ '+k);return v},secret(k){let v=this.get(k);if(!v){v=(Utilities.getUuid()+Utilities.getUuid()).replace(/-/g,'');this.set(k,v)}return v}});
