const AIService=Object.freeze({generate(c,p){PermissionService.requireAny(c,['ai.use','system.manage']);if(!Utils.bool(Props.get('AI_ENABLED','false')))throw AppError.configuration('AI ยังไม่เปิด');const r=UrlFetchApp.fetch(Props.required('AI_ENDPOINT'),{method:'post',contentType:'application/json',headers:Props.get('AI_API_KEY')?{Authorization:'Bearer '+Props.get('AI_API_KEY')}:{},payload:JSON.stringify({model:Props.get('AI_MODEL',''),prompt:p.prompt||'',systemPrompt:p.systemPrompt||'',responseFormat:p.responseFormat||'JSON'}),muteHttpExceptions:true});if(r.getResponseCode()>=300)throw new AppError('AI_PROVIDER_ERROR',r.getContentText());return Utils.parse(r.getContentText(),{text:r.getContentText()})}});
