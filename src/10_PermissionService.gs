const ROLE_PERMISSIONS={SYSTEM_ADMIN:['*'],SCHOOL_ADMIN:['user.*','class.*','student.*','teacher.*','subject.*','quiz.*','exam.*','report.*','notification.*','file.*','system.monitor'],TEACHER:['class.read','student.read','subject.read','quiz.*','exam.grade','report.read','notification.send','file.*','ai.use'],STUDENT:['quiz.available','exam.start','exam.submit','score.read','file.read'],PARENT:['score.read'],GUEST:[]};
const PermissionService=Object.freeze({has(c,p){const a=[...(ROLE_PERMISSIONS[c.role]||[]),...Utils.arr(c.permissions)];return a.includes('*')||a.includes(p)||a.some(x=>x.endsWith('.*')&&p.startsWith(x.slice(0,-1)))},require(c,p){if(!this.has(c,p))throw AppError.permission();return true},requireAny(c,a){if(!a.some(p=>this.has(c,p)))throw AppError.permission();return true}});
