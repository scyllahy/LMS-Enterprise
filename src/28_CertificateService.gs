const CertificateService=Object.freeze({generate(c,p){const no='CER-'+(new Date().getFullYear()+543)+'-'+String(Date.now()).slice(-8),html='<html><body style="text-align:center;padding:60px;font-family:sans-serif"><h1>เกียรติบัตร</h1><h2>'+Utils.escape(p.recipientName)+'</h2><p>'+Utils.escape(p.description||'ผ่านการประเมิน')+'</p><p>'+no+'</p></body></html>';return StorageService.upload(c,{blob:Utilities.newBlob(html,'text/html',no+'.html'),entity:'Certificate',entityId:p.studentId||'',metadataJson:{certificateNo:no}})}});
