const EmailService=Object.freeze({sendNotification(n,d){return this.send({to:d.destination,subject:n.title,body:n.message,htmlBody:'<p>'+Utils.escape(n.message).replace(/\n/g,'<br>')+'</p>'})},send(p){const to=Utils.email(p.to);if(!to)throw AppError.validation('อีเมลไม่ถูกต้อง');MailApp.sendEmail({to,subject:Utils.text(p.subject),body:p.body||'',htmlBody:p.htmlBody||undefined,name:APP_CONFIG.app.name});return{success:true,to,quota:MailApp.getRemainingDailyQuota()}}});
