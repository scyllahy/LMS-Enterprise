const ScoringService=Object.freeze({autoGrade(c,id){const a=AttemptRepository.findById(id),qs=QuestionRepository.findMany({quizId:a.quizId}),ans=AnswerRepository.findMany({attemptId:id});let total=0,max=0,pending=false;qs.forEach(q=>{max+=Utils.num(q.score);const x=ans.find(z=>z.questionId===q.questionId);let e=0;if(x){if(q.questionType===QUESTION_TYPES.ESSAY)pending=true;else e=correct_(q,x.answerJson)?Utils.num(q.score):0;AnswerRepository.update(x.answerId,{autoScore:e,finalScore:e},{actorId:c.userId})}total+=e});const quiz=QuizRepository.findById(a.quizId),pct=max?total/max*100:0,d={attemptId:id,quizId:a.quizId,studentId:a.studentId,autoScore:total,manualScore:0,bonusScore:0,penaltyScore:0,finalScore:total,maximumScore:max,percentage:pct,passed:pct>=Utils.num(quiz.passPercentage,50),published:!pending,metadataJson:{pendingManual:pending}},old=ScoreRepository.findOne({attemptId:id}),score=old?ScoreRepository.update(old.scoreId,d,{actorId:c.userId}):ScoreRepository.insert(d,{actorId:c.userId});AttemptRepository.update(id,{examStatus:pending?EXAM_STATUSES.SUBMITTED:EXAM_STATUSES.GRADED,score:total,maximumScore:max,percentage:pct},{actorId:c.userId});return score}});
function correct_(q,a){const z=q.correctAnswerJson||{};if(q.questionType===QUESTION_TYPES.MULTIPLE_ANSWER)return JSON.stringify(Utils.arr(a.values).sort())===JSON.stringify(Utils.arr(z.values).sort());return String(a.value??a.key??'')===String(z.value??z.key??'')}
