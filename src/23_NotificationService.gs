const NotificationService=Object.freeze({send(c,p){PermissionService.requireAny(c,['notification.send','system.manage']);const n=NotificationRepository.insert({type:p.type||'GENERAL',title:p.title||'',message:p.message||'',channelsJson:Utils.arr(p.channels||['EMAIL']),recipientsJson:Utils.arr(p.recipients),scheduledAt:p.scheduledAt||'',sentAt:'',resultJson:{}},{actorId:c.userId}),r=[];Utils.arr(n.recipientsJson).forEach(x=>Utils.arr(n.channelsJson).forEach(ch=>{try{if(ch==='EMAIL'&&x.email)r.push(EmailService.sendNotification(n,{destination:x.email}));if(ch==='LINE'&&x.lineUserId)r.push(LineService.sendNotification(n,{destination:x.lineUserId}));if(ch==='TELEGRAM'&&x.telegramChatId)r.push(TelegramService.sendNotification(n,{destination:x.telegramChatId}))}catch(e){r.push({success:false,error:e.message})}}));return NotificationRepository.update(n.notificationId,{sentAt:Utils.now(),resultJson:r},{actorId:c.userId})}});
