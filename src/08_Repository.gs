function repo_(name,idField,prefix){return Object.freeze({headers(){return getSchema_()[name]},sheet(){return DB.sheet(name,this.headers())},all(){const sh=this.sheet(),h=this.headers(),rows=sh.getDataRange().getValues();if(rows.length<2)return[];return rows.slice(1).map(r=>{const o={};h.forEach((k,i)=>o[k]=cellOut_(r[i]));return o})},findById(id){return this.all().find(x=>String(x[idField])===String(id))||null},findOne(f){return this.all().find(x=>match_(x,f||{}))||null},findMany(f){return this.all().filter(x=>match_(x,f||{}))},count(f){return this.findMany(f).length},insert(d,opt={}){const h=this.headers(),n=Utils.now(),x=Object.assign({},d);if(!x[idField])x[idField]=Utils.id(prefix);if(h.includes('status')&&!x.status)x.status=APP_STATUSES.ACTIVE;if(h.includes('createdAt'))x.createdAt=n;if(h.includes('createdBy'))x.createdBy=opt.actorId||'SYSTEM';if(h.includes('updatedAt'))x.updatedAt=n;if(h.includes('updatedBy'))x.updatedBy=opt.actorId||'SYSTEM';this.sheet().appendRow(h.map(k=>cellIn_(x[k])));return x},update(id,d,opt={}){const h=this.headers(),rows=this.all(),i=rows.findIndex(x=>String(x[idField])===String(id));if(i<0)throw AppError.notFound('ไม่พบ '+name);const x=Object.assign({},rows[i],d);if(h.includes('updatedAt'))x.updatedAt=Utils.now();if(h.includes('updatedBy'))x.updatedBy=opt.actorId||'SYSTEM';this.sheet().getRange(i+2,1,1,h.length).setValues([h.map(k=>cellIn_(x[k]))]);return x}})}
function match_(r,f){return Object.keys(f||{}).every(k=>String(r[k]??'')===String(f[k]??''))}
function cellIn_(v){return Utils.isObject(v)||Array.isArray(v)?JSON.stringify(v):(v??'')}
function cellOut_(v){if(typeof v!=='string')return v;const s=v.trim();return ((s[0]==='{'&&s.endsWith('}'))||(s[0]==='['&&s.endsWith(']')))?Utils.parse(s,v):v}
