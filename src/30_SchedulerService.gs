const SchedulerService=Object.freeze({installDefaults(c){[['Expire Exams','jobExpireExams_'],['System Health','jobSystemHealth_']].forEach(x=>{if(!JobRepository.findOne({jobName:x[0]}))JobRepository.insert({jobName:x[0],handlerName:x[1],frequency:'EVERY_MINUTE',parametersJson:{},lastRunAt:'',lastStatus:'',lastError:''},{actorId:c.userId})});if(!ScriptApp.getProjectTriggers().some(t=>t.getHandlerFunction()==='runScheduledJobs'))ScriptApp.newTrigger('runScheduledJobs').timeBased().everyMinutes(1).create();return{installed:true}},run(c){return JobRepository.findMany({status:APP_STATUSES.ACTIVE}).map(j=>{try{const r=({jobExpireExams_,jobSystemHealth_}[j.handlerName])(c,j.parametersJson||{});JobRepository.update(j.jobId,{lastRunAt:Utils.now(),lastStatus:'SUCCESS',lastError:''},{actorId:c.userId});return{success:true,result:r}}catch(e){JobRepository.update(j.jobId,{lastRunAt:Utils.now(),lastStatus:'FAILED',lastError:e.message},{actorId:c.userId});return{success:false,error:e.message}}})}});
function jobExpireExams_(c){return AttemptRepository.findMany({examStatus:EXAM_STATUSES.IN_PROGRESS}).filter(a=>a.endsAt&&new Date(a.endsAt)<new Date()).map(a=>ExamEngine.autoSubmit(c,a.attemptId))}
function jobSystemHealth_(c){return SystemMonitorService.healthCheck(c)}
function runScheduledJobs(){return SchedulerService.run(systemContext_('SCHEDULER'))}
