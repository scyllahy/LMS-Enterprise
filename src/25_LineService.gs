const LineService=Object.freeze({sendNotification(n,d){return this.push(d.destination,{type:'text',text:n.title+'\n'+n.message})},push(id,msg){const t=Props.required('LINE_CHANNEL_ACCESS_TOKEN'),r=UrlFetchApp.fetch('https://api.line.me/v2/bot/message/push',{method:'post',contentType:'application/json',headers:{Authorization:'Bearer '+t},payload:JSON.stringify({to:String(id),messages:[msg]}),muteHttpExceptions:true});if(r.getResponseCode()>=300)throw new AppError('LINE_API_ERROR',r.getContentText());return{success:true}}});
