const StorageService=Object.freeze({root(){let id=Props.get('LMS_ROOT_FOLDER_ID');if(!id){const f=DriveApp.createFolder(APP_CONFIG.app.name);id=f.getId();Props.set('LMS_ROOT_FOLDER_ID',id);return f}return DriveApp.getFolderById(id)},upload(c,p){PermissionService.requireAny(c,['file.create','system.manage']);const b=p.blob;if(!b||typeof b.getBytes!=='function')throw AppError.validation('ไม่พบไฟล์');if(b.getBytes().length>APP_CONFIG.storage.maxBytes)throw AppError.validation('ไฟล์ใหญ่เกินกำหนด');const f=this.root().createFile(b);return FileRepository.insert({driveFileId:f.getId(),entity:p.entity||'File',entityId:p.entityId||'',ownerId:c.userId,fileName:f.getName(),mimeType:b.getContentType(),sizeBytes:b.getBytes().length,url:f.getUrl(),metadataJson:p.metadataJson||{}},{actorId:c.userId})}});
